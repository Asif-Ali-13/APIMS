# Server
NODE_ENV=development
PORT=5000


# MongoDB (docker compose: localhost:27017)
MONGO_URI=mongodb://localhost:27017/api_monitoring
MONGO_DB_NAME=api_monitoring


# PostgreSQL (docker compose credentials)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=api_monitoring
PG_USER=postgres
PG_PASSWORD=asif-postgres


# RabbitMQ — must match docker-compose rabbitmq service
RABBITMQ_URL=amqp://api_user:asif-rabbitmq@localhost:5672/api_monitoring
RABBITMQ_QUEUE=api_hits


# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h


# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
