{
  "name": "api-hit-monitoring",
  "version": "1.0.0",
  "description": "Real time API hit tracking and monitoring system",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node --enable-source-maps dist/server.js",
    "dev": "tsx watch src/server.ts",
    "processor": "tsx src/services/processor/consumer.ts",
    "init": "npm run build && node dist/shared/scripts/init.js",
    "init:env": "cp .env.example .env && echo \"Environment file created\""
  },
  "keywords": [
    "api",
    "monitoring",
    "tracking",
    "analytics"
  ],
  "author": "Asif Ali",
  "license": "MIT",
  "dependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/pg": "^8.20.0",
    "amqplib": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "pg": "^8.20.0",
    "uuid": "^8.3.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
