# Blog API
PORT=3002
SERVICE_NAME=blog-api
NODE_ENV=development

# API Hit Monitoring ingest (fill after onboarding in the main server)
MONITORING_API_KEY=your_api_key_here
# Use 5001 when the monitoring server runs via docker compose (maps host 5001 → container 5000).
# Use 5000 when you run `npm run dev` in server/ locally.
MONITORING_ENDPOINT=http://localhost:5001/api/hit
MONITORING_ENABLED=true
